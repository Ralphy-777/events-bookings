# Auto detect text files and perform LF normalization
* text=auto

# Force LF for these file types
*.ts   text eol=lf
*.tsx  text eol=lf
*.js   text eol=lf
*.jsx  text eol=lf
*.json text eol=lf
*.css  text eol=lf
*.md   text eol=lf
*.py   text eol=lf
*.yml  text eol=lf
*.yaml text eol=lf
*.sh   text eol=lf

# Binary files
*.png  binary
*.jpg  binary
*.ico  binary
*.svg  binary
